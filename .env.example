# SMTP Configuration for Contact Form
# Copy this file to .env.local and replace with your actual SMTP credentials

# SMTP Server (e.g., smtp.gmail.com, smtp-mail.outlook.com, smtp.hostinger.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (usually 587 for TLS, 465 for SSL, 25 for non-secure)
SMTP_PORT=587

# SMTP Username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP Password (use App Password for Gmail, not your regular password)
SMTP_PASSWORD=your-app-password

# Email address to receive contact form submissions
CONTACT_EMAIL=info@paninfra.com

# "From" email address (should be same as SMTP_USER or authorized sender)
SMTP_FROM=your-email@gmail.com
